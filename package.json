{
  "name": "chatbot-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace=apps/admin-web",
    "dev:widget": "npm run dev --workspace=apps/embed-widget",
    "dev:demo": "npm run dev --workspace=apps/demo-site",
    "build:admin": "npm run build --workspace=apps/admin-web",
    "build:widget": "npm run build --workspace=apps/embed-widget",
    "build:demo": "npm run build --workspace=apps/demo-site",
    "build:all": "npm run build:widget && npm run build:admin && npm run build:demo"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "playwright": "^1.61.0"
  }
}
