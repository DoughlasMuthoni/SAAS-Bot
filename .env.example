APP_ENV=development
APP_URL=http://localhost:8000
ADMIN_WEB_URL=http://localhost:3000
WIDGET_WEB_URL=http://localhost:3001

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=chatbot_platform
MYSQL_USER=root
MYSQL_PASSWORD=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_MAIN=claude-sonnet-4-6
ANTHROPIC_MODEL_ADVANCED=claude-opus-4-7
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
VOYAGE_API_KEY=

JWT_SECRET=change-me-to-a-long-random-string
SESSION_SECRET=change-me-to-another-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20

RATE_LIMIT_PER_MINUTE=30
MAX_HISTORY_MESSAGES=10
MAX_TOKENS_PER_RESPONSE=1024
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

EMBEDDING_PROVIDER=local
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=./chroma_data

REDIS_URL=

LOG_LEVEL=INFO
WIDGET_BUNDLE_URL=http://localhost:8000/static/widget.js

